<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="FIS_DB"
			 connectionString="Server=localhost;Database=fis_db;Uid=root;Pwd=;SslMode=None;"
			 providerName="MySql.Data.MySqlClient" />
	</connectionStrings>
	
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>